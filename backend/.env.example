# ── Server ────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=lumeva_secret_change_me_in_production
JWT_EXPIRES_IN=7d

# ── Products ──────────────────────────────────────────────────────────
PRODUCTS_PATH=../products.json

# ── M-Pesa Daraja ─────────────────────────────────────────────────────
# Get these from https://developer.safaricom.co.ke
MPESA_ENV=sandbox
# sandbox base URL: https://sandbox.safaricom.co.ke
# production base URL: https://api.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# URL Safaricom will POST the payment result to (must be HTTPS in production)
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback

# ── Resend (email) ────────────────────────────────────────────────────
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here
# The "From" address — must be a verified domain in Resend
EMAIL_FROM=LUMEVA <orders@yourdomain.com>
